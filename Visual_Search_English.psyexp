      <CodeComponent name="Fb_Code" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="feedback_text = &quot;&quot;;&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="# Initialize feedback text&amp;#10;feedback_text = &quot;&quot;" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Py" valType="str" updates="None" name="Code Type"/>
        <Param val="# Initialize clicked_image&amp;#10;clicked_image = None&amp;#10;&amp;#10;# Check for mouse clicks&amp;#10;if mouse_resp.getPressed()[0]:  # Check if the left mouse button is pressed&amp;#10;    # Check each image component for clicks&amp;#10;    if mouse_resp.isPressedIn(num1):&amp;#10;        clicked_image = cue1  # Get the path of the clicked image&amp;#10;    elif mouse_resp.isPressedIn(num2):&amp;#10;        clicked_image = cue2&amp;#10;    elif mouse_resp.isPressedIn(num3):&amp;#10;        clicked_image = cue3&amp;#10;    elif mouse_resp.isPressedIn(num4):&amp;#10;        clicked_image = cue4&amp;#10;    elif mouse_resp.isPressedIn(num5):&amp;#10;        clicked_image = cue5&amp;#10;    elif mouse_resp.isPressedIn(num6):&amp;#10;        clicked_image = cue6&amp;#10;    elif mouse_resp.isPressedIn(num7):&amp;#10;        clicked_image = cue7&amp;#10;    elif mouse_resp.isPressedIn(num8):&amp;#10;        clicked_image = cue8&amp;#10;    elif mouse_resp.isPressedIn(num9):&amp;#10;        clicked_image = cue9&amp;#10;&amp;#10;    # Provide feedback based on the clicked image&amp;#10;    if clicked_image is not None:&amp;#10;        # Get the correct response from the Practice file&amp;#10;        correct_response = str(cor_resp)  # This should be the full path to the correct image&amp;#10;        if clicked_image == correct_response:&amp;#10;            feedback_text = &quot;Correct!&quot;&amp;#10;        else:&amp;#10;            feedback_text = &quot;Incorrect!&quot;&amp;#10;        &amp;#10;        continueRoutine = False  # End the routine after a response" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="if (((((((((mouse_resp.isPressedIn(num1) || mouse_resp.isPressedIn(num2)) || mouse_resp.isPressedIn(num3)) || mouse_resp.isPressedIn(num4)) || mouse_resp.isPressedIn(num5)) || mouse_resp.isPressedIn(num6)) || mouse_resp.isPressedIn(num7)) || mouse_resp.isPressedIn(num8)) || mouse_resp.isPressedIn(num9))) {&amp;#10;    clicked_name = &quot;&quot;;&amp;#10;    if (mouse_resp.isPressedIn(num1)) {&amp;#10;        clicked_name = &quot;cue1&quot;;&amp;#10;    } else {&amp;#10;        if (mouse_resp.isPressedIn(num2)) {&amp;#10;            clicked_name = &quot;cue2&quot;;&amp;#10;        } else {&amp;#10;            if (mouse_resp.isPressedIn(num3)) {&amp;#10;                clicked_name = &quot;cue3&quot;;&amp;#10;            } else {&amp;#10;                if (mouse_resp.isPressedIn(num4)) {&amp;#10;                    clicked_name = &quot;cue4&quot;;&amp;#10;                } else {&amp;#10;                    if (mouse_resp.isPressedIn(num5)) {&amp;#10;                        clicked_name = &quot;cue5&quot;;&amp;#10;                    } else {&amp;#10;                        if (mouse_resp.isPressedIn(num6)) {&amp;#10;                            clicked_name = &quot;cue6&quot;;&amp;#10;                        } else {&amp;#10;                            if (mouse_resp.isPressedIn(num7)) {&amp;#10;                                clicked_name = &quot;cue7&quot;;&amp;#10;                            } else {&amp;#10;                                if (mouse_resp.isPressedIn(num8)) {&amp;#10;                                    clicked_name = &quot;cue8&quot;;&amp;#10;                                } else {&amp;#10;                                    if (mouse_resp.isPressedIn(num9)) {&amp;#10;                                        clicked_name = &quot;cue9&quot;;&amp;#10;                                    }&amp;#10;                                }&amp;#10;                            }&amp;#10;                        }&amp;#10;                    }&amp;#10;                }&amp;#10;            }&amp;#10;        }&amp;#10;    }&amp;#10;    if (clicked_name) {&amp;#10;        if ((clicked_name === correct_answer)) {&amp;#10;            feedback_text = &quot;Correct!&quot;;&amp;#10;        } else {&amp;#10;            feedback_text = &quot;Incorrect.&quot;;&amp;#10;        }&amp;#10;        continueRoutine = false;&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="console.log(feedback_text);&amp;#10;" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
        <Param val="Fb_Code" valType="code" updates="None" name="name"/>
      </CodeComponent>
    </Routine>
